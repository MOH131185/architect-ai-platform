{
  "name": "architect-ai-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "proxy": "http://localhost:3001",
  "engines": {
    "node": ">=18.0.0 <21.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.29.2",
    "@clerk/backend": "^3.2.11",
    "@clerk/clerk-react": "^5.61.5",
    "@fal-ai/serverless-client": "^0.10.4",
    "@googlemaps/react-wrapper": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/supabase-js": "^2.103.2",
    "@turf/turf": "^7.3.2",
    "@types/three": "^0.180.0",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "crypto-browserify": "^3.12.1",
    "crypto-js": "^4.2.0",
    "d3": "^7.9.0",
    "dompurify": "^3.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.23.24",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.2",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.525.0",
    "makerjs": "^0.18.1",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "pixelmatch": "^5.3.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "replicate": "^1.4.0",
    "sharp": "^0.33.5",
    "stripe": "^22.0.1",
    "suncalc": "^1.9.0",
    "svg.js": "^2.7.1",
    "svg2pdf.js": "^2.2.4",
    "tailwind-merge": "^3.4.0",
    "three": "^0.180.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "server": "node server.cjs",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "build": "react-scripts build",
    "build:active": "node scripts/run-build-active.cjs",
    "build:vercel": "CI=false react-scripts build",
    "test": "react-scripts test",
    "test:compose:routing": "node scripts/tests/test-compose-core-and-routing.mjs",
    "test:dna:pipeline": "node test-dna-pipeline.js",
    "test:clinic:a1": "node test-clinic-a1-generation.js",
    "test:ci": "react-scripts test --watchAll=false --ci",
    "test:coverage": "react-scripts test --watchAll=false --coverage",
    "eject": "react-scripts eject",
    "check:env": "node scripts/check-env.cjs",
    "check:contracts": "node scripts/check-contracts.cjs",
    "check:genarch-contracts": "node scripts/check-genarch-contracts.cjs",
    "check:all": "npm run check:env && npm run check:contracts",
    "validate:active": "npm run check:contracts && npm run test:compose:routing && npm run test:dna:pipeline && npm run test:clinic:a1",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"api/**/*.js\" \"scripts/**/*.js\" \"server.cjs\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\" \"api/**/*.{js,json}\" \"scripts/**/*.{js,json}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\" \"api/**/*.{js,json}\" \"scripts/**/*.{js,json}\" \"*.{js,json,md}\"",
    "prebuild": "echo 'Skipping prebuild checks for faster deployment'",
    "prepare": "husky",
    "clean": "rm -rf build coverage .eslintcache node_modules/.cache .turbo",
    "clean:all": "npm run clean && rm -rf node_modules package-lock.json",
    "reset": "npm run clean:all && npm install",
    "verify": "npm run verify:active",
    "verify:active": "npm run validate:active && npm run build:active",
    "ci:active": "npm run verify:active",
    "qa:test": "react-scripts test --testPathPattern=src/__tests__/qa --watchAll=false --passWithNoTests"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "import/no-anonymous-default-export": "off"
    },
    "overrides": [
      {
        "files": [
          "server.cjs",
          "api/a1/compose.js",
          "src/services/design/panelGenerationService.js",
          "src/services/dnaWorkflowOrchestrator.js"
        ],
        "rules": {
          "no-unused-vars": "off"
        }
      },
      {
        "files": [
          "src/services/**/*.{js,jsx}"
        ],
        "rules": {
          "no-unused-vars": "off"
        }
      },
      {
        "files": [
          "src/geometry/**/*.{js,jsx,ts,tsx}",
          "src/utils/polygonSimplifier.js",
          "src/utils/svgPathValidator.js"
        ],
        "rules": {
          "no-unused-vars": "off",
          "@typescript-eslint/no-unused-vars": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(@turf|geokdbush|tinyqueue|polyclip-ts|bignumber\\.js|robust-predicates|d3-.*|splaytree-ts|sweepline-intersections)/)"
    ],
    "moduleNameMapper": {
      "^@img/(sharp-[^/]+)/sharp\\.node$": "<rootDir>/node_modules/@img/$1/lib/$1.node"
    },
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/reportWebVitals.js",
      "!src/**/*.test.{js,jsx}",
      "!src/**/__tests__/**"
    ]
  }
}
