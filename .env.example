# Architecture AI Platform .env template
# Copy this file to .env in your repo root and fill the REPLACE_ME values.
# Never commit real secrets. Add `.env` to .gitignore.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=architecture-ai-riba-a1-platform
APP_REGION=uk
APP_TIMEZONE=Europe/London
LOG_LEVEL=info

# Use base models now, then switch to hybrid or fine_tuned after training jobs exist.
# base       = always use foundation models below
# hybrid     = use fine-tuned model when a *_FT_MODEL variable is filled, otherwise base
# fine_tuned = require fine-tuned models and fail fast when missing
MODEL_SOURCE=hybrid
MODEL_FALLBACK_POLICY=use_base_when_ft_missing

# -----------------------------------------------------------------------------
# OpenAI core API (server-side only)
# All OPENAI_*_API_KEY values below are read by Node/Vercel server code.
# Server resolution order:
#   reasoning : OPENAI_REASONING_API_KEY -> OPENAI_API_KEY
#   image gen : OPENAI_IMAGES_API_KEY    -> OPENAI_API_KEY -> OPENAI_REASONING_API_KEY
# Never publish these in client builds. REACT_APP_OPENAI_API_KEY is for local
# dev only and is ignored by the server unless OPENAI_ALLOW_REACT_APP_SERVER_KEY
# is explicitly true outside production.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=REPLACE_ME_OPENAI_API_KEY
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_BASE_URL=https://api.openai.com/v1

# Production base models before fine-tuning
# Current API docs recommend gpt-5.4 for complex reasoning/coding and gpt-5.4-mini/nano for cost/latency.
OPENAI_REASONING_MODEL=gpt-5.4
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_CHEAP_MODEL=gpt-5.4-nano
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_FAST_MODEL=text-embedding-3-small

# Global model controls
OPENAI_TEMPERATURE_CREATIVE=0.7
OPENAI_TEMPERATURE_FACTUAL=0.15
OPENAI_TEMPERATURE_STRICT=0.0
OPENAI_MAX_OUTPUT_TOKENS_LARGE=32000
OPENAI_MAX_OUTPUT_TOKENS_SMALL=8000
OPENAI_REASONING_EFFORT=high
OPENAI_REQUEST_TIMEOUT_SECONDS=180
OPENAI_RETRY_MAX=4
OPENAI_BATCH_ENABLED=true
OPENAI_STRUCTURED_OUTPUTS=true

# ProjectGraph OpenAI reasoning checkpoints
# Default is required outside tests. Use disabled only for explicit local deterministic smoke runs.
PROJECT_GRAPH_OPENAI_REASONING_MODE=required

# ProjectGraph visual image generation
# PROJECT_GRAPH_IMAGE_GEN_ENABLED=true is required for photoreal exterior,
# interior, hero, and axonometric panels. When false, A1 uses deterministic
# fallback visuals and OpenAI image usage will remain zero.
PROJECT_GRAPH_IMAGE_GEN_ENABLED=false
# If true, visual panels fail instead of silently falling back when OpenAI image generation fails.
OPENAI_STRICT_IMAGE_GEN=false
# Optional: enable AI texture thumbnails over the procedural material cards.
# false = deterministic procedural SVG texture cards only (default, free, no OpenAI usage).
# true  = request small texture thumbnails from a configured image provider per A1 sheet
#         (max 8, keyed by materialSignature); on any failure falls back to the procedural pattern.
# Independent of PROJECT_GRAPH_IMAGE_GEN_ENABLED. Do not enable automatically.
MATERIAL_TEXTURE_THUMBNAILS_ENABLED=false
# Local-dev compatibility only. Server-side OpenAI calls ignore REACT_APP_OPENAI_API_KEY unless this is true outside production.
OPENAI_ALLOW_REACT_APP_SERVER_KEY=false

# -----------------------------------------------------------------------------
# Fine-tuning base models supported by current OpenAI docs
# Fill *_FT_MODEL only after the fine-tuning job completes.
# Example: ft:gpt-4.1-mini-2025-04-14:your-org:brief-parser:abc123
# -----------------------------------------------------------------------------
OPENAI_SFT_BASE_MODEL_HIGH=gpt-4.1-2025-04-14
OPENAI_SFT_BASE_MODEL_FAST=gpt-4.1-mini-2025-04-14
OPENAI_SFT_BASE_MODEL_CHEAP=gpt-4.1-nano-2025-04-14
OPENAI_DPO_BASE_MODEL_HIGH=gpt-4.1-2025-04-14
OPENAI_DPO_BASE_MODEL_FAST=gpt-4.1-mini-2025-04-14
OPENAI_DPO_BASE_MODEL_CHEAP=gpt-4.1-nano-2025-04-14
OPENAI_VISION_FT_BASE_MODEL=gpt-4o-2024-08-06
OPENAI_RFT_BASE_MODEL=o4-mini-2025-04-16

# -----------------------------------------------------------------------------
# Step 00 — request router and pipeline orchestrator
# -----------------------------------------------------------------------------
STEP_00_ROUTER_API_KEY_ENV=OPENAI_API_KEY
STEP_00_ROUTER_MODEL=gpt-5.4-mini
STEP_00_ROUTER_FT_METHOD=sft
STEP_00_ROUTER_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_00_ROUTER_FT_MODEL=

STEP_00_ORCHESTRATOR_API_KEY_ENV=OPENAI_API_KEY
STEP_00_ORCHESTRATOR_MODEL=gpt-5.4
STEP_00_ORCHESTRATOR_FT_METHOD=none
STEP_00_ORCHESTRATOR_FT_BASE_MODEL=
STEP_00_ORCHESTRATOR_FT_MODEL=

# -----------------------------------------------------------------------------
# Step 01 — brief intake, user desire, RIBA stage, constraints, output schema
# -----------------------------------------------------------------------------
STEP_01_BRIEF_API_KEY_ENV=OPENAI_API_KEY
STEP_01_BRIEF_MODEL=gpt-5.4-mini
STEP_01_BRIEF_TEMPERATURE=0.15
STEP_01_BRIEF_FT_METHOD=sft
STEP_01_BRIEF_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_01_BRIEF_FT_MODEL=
STEP_01_BRIEF_SCHEMA_PATH=schemas/brief.normalized.schema.json

STEP_01_STYLE_DESIRE_API_KEY_ENV=OPENAI_API_KEY
STEP_01_STYLE_DESIRE_MODEL=gpt-5.4-mini
STEP_01_STYLE_DESIRE_FT_METHOD=dpo
STEP_01_STYLE_DESIRE_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_01_STYLE_DESIRE_FT_MODEL=

# -----------------------------------------------------------------------------
# Step 02 — site, local town/city, planning context, OS maps and surrounding fabric
# -----------------------------------------------------------------------------
STEP_02_SITE_API_KEY_ENV=OPENAI_API_KEY
STEP_02_SITE_MODEL=gpt-5.4
STEP_02_SITE_FT_METHOD=sft
STEP_02_SITE_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_02_SITE_FT_MODEL=

# Ordnance Survey / OS Data Hub for UK mapping, features, building footprints, context.
OS_DATAHUB_API_KEY=REPLACE_ME_OS_DATAHUB_API_KEY
OS_MAPS_API_KEY=REPLACE_ME_OS_MAPS_API_KEY
OS_FEATURES_API_KEY=REPLACE_ME_OS_FEATURES_API_KEY
OS_NGD_API_KEY=REPLACE_ME_OS_NGD_API_KEY
OS_VECTOR_TILE_API_KEY=REPLACE_ME_OS_VECTOR_TILE_API_KEY

# Optional geocoding fallback. Prefer OS Places / OS APIs for UK production.
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
NOMINATIM_USER_AGENT=architecture-ai-platform/1.0 contact@example.com

# Planning Data Platform for conservation areas, listed buildings, brownfield land, etc.
# It is usually usable without a key, but leave this for gateways/proxies or paid aggregators.
PLANNING_DATA_API_KEY=
PLANNING_DATA_BASE_URL=https://www.planning.data.gov.uk
HISTORIC_ENGLAND_API_KEY=
LOCAL_AUTHORITY_PLANNING_API_KEY=

# Environment Agency and local constraints.
ENVIRONMENT_AGENCY_API_KEY=
EA_FLOOD_MAP_API_KEY=
EA_FLOOD_MONITORING_BASE_URL=https://environment.data.gov.uk/flood-monitoring

# -----------------------------------------------------------------------------
# Step 03 — climate, overheating, daylight, passive strategy, local environmental response
# -----------------------------------------------------------------------------
STEP_03_CLIMATE_API_KEY_ENV=OPENAI_API_KEY
STEP_03_CLIMATE_MODEL=gpt-5.4
STEP_03_CLIMATE_FT_METHOD=sft_then_rft
STEP_03_CLIMATE_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_03_CLIMATE_RFT_BASE_MODEL=o4-mini-2025-04-16
STEP_03_CLIMATE_FT_MODEL=
STEP_03_CLIMATE_RFT_MODEL=

METOFFICE_DATAHUB_API_KEY=REPLACE_ME_METOFFICE_DATAHUB_API_KEY
METOFFICE_DATAHUB_BASE_URL=https://data.hub.api.metoffice.gov.uk
UKCP_API_KEY=REPLACE_ME_UKCP_API_KEY
UKCP_BASE_URL=https://ukclimateprojections-ui.metoffice.gov.uk
OPEN_METEO_FALLBACK_ENABLED=true
OPEN_METEO_BASE_URL=https://api.open-meteo.com

# Local design-analysis defaults. Replace per project.
DEFAULT_WEATHER_LOCATION_NAME=London
DEFAULT_LATITUDE=51.5072
DEFAULT_LONGITUDE=-0.1276
DEFAULT_CLIMATE_SCENARIO=UKCP18_RCP85_2050S_HIGH_RISK_CHECK
DEFAULT_OVERHEATING_STANDARD=Approved_Document_O_plus_CIBSE_TM59_where_applicable
DAYLIGHT_ANALYSIS_ENGINE=radiance
ENERGY_ANALYSIS_ENGINE=energyplus

# -----------------------------------------------------------------------------
# Step 04 — regulation/RAG/checklists: Building Regulations, Approved Documents, local plan
# -----------------------------------------------------------------------------
STEP_04_REGS_API_KEY_ENV=OPENAI_API_KEY
STEP_04_REGS_MODEL=gpt-5.4
STEP_04_REGS_TEMPERATURE=0.0
STEP_04_REGS_FT_METHOD=sft_then_rft
STEP_04_REGS_FT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_04_REGS_RFT_BASE_MODEL=o4-mini-2025-04-16
STEP_04_REGS_FT_MODEL=
STEP_04_REGS_RFT_MODEL=

REGULATION_VECTOR_API_KEY_ENV=OPENAI_API_KEY
REGULATION_EMBEDDING_MODEL=text-embedding-3-large
REGULATION_PACK_PATH=data/regulations/uk-england-approved-documents
REGULATION_JURISDICTION_DEFAULT=England
REGULATION_ASSUME_PROJECT_IS_BUILDING_CONTROL_CERTIFIED=false
REGULATION_REQUIRE_SOURCE_CITATIONS=true
GOVUK_CONTENT_API_KEY=
GOVUK_BASE_URL=https://www.gov.uk

# EPC / operational energy data, optional.
EPC_API_USERNAME=
EPC_API_KEY=
EPC_BASE_URL=https://epc.opendatacommunities.org/api/v1

# -----------------------------------------------------------------------------
# Step 05 — programme, accommodation schedule, adjacency, net/gross areas
# -----------------------------------------------------------------------------
STEP_05_PROGRAMME_API_KEY_ENV=OPENAI_API_KEY
STEP_05_PROGRAMME_MODEL=gpt-5.4
STEP_05_PROGRAMME_TEMPERATURE=0.15
STEP_05_PROGRAMME_FT_METHOD=sft
STEP_05_PROGRAMME_FT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_05_PROGRAMME_FT_MODEL=
STEP_05_PROGRAMME_SCHEMA_PATH=schemas/programme.schema.json
PROGRAMME_LIBRARY_PATH=data/programmes/uk_typologies
AREA_STANDARD_LIBRARY_PATH=data/standards/area-benchmarks

# -----------------------------------------------------------------------------
# Step 06 — concept, massing, urban response, architectural language
# -----------------------------------------------------------------------------
STEP_06_CONCEPT_API_KEY_ENV=OPENAI_API_KEY
STEP_06_CONCEPT_MODEL=gpt-5.4
STEP_06_CONCEPT_TEMPERATURE=0.7
STEP_06_CONCEPT_FT_METHOD=dpo
STEP_06_CONCEPT_FT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_06_CONCEPT_FT_MODEL=

STEP_06_MASSING_API_KEY_ENV=OPENAI_API_KEY
STEP_06_MASSING_MODEL=gpt-5.4
STEP_06_MASSING_TEMPERATURE=0.2
STEP_06_MASSING_FT_METHOD=sft
STEP_06_MASSING_FT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_06_MASSING_FT_MODEL=
STEP_06_MASSING_SCHEMA_PATH=schemas/massing.schema.json

# -----------------------------------------------------------------------------
# Step 07 — semantic ProjectGraph / BIM-lite source of truth
# All 2D and 3D must be generated from this graph, never independently.
# -----------------------------------------------------------------------------
STEP_07_PROJECT_GRAPH_API_KEY_ENV=OPENAI_API_KEY
STEP_07_PROJECT_GRAPH_MODEL=gpt-5.4
STEP_07_PROJECT_GRAPH_TEMPERATURE=0.0
STEP_07_PROJECT_GRAPH_FT_METHOD=sft
STEP_07_PROJECT_GRAPH_FT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_07_PROJECT_GRAPH_FT_MODEL=
STEP_07_PROJECT_GRAPH_SCHEMA_PATH=schemas/project_graph.schema.json
PROJECT_GRAPH_STRICT_VALIDATION=true
PROJECT_GRAPH_AUTOFIX_MAX_ITERATIONS=4
PROJECT_GRAPH_REQUIRE_2D_3D_SAME_SOURCE=true

# -----------------------------------------------------------------------------
# Step 08 — 2D technical drawing generation from ProjectGraph
# Do not fine-tune this as a drawing generator; use deterministic CAD/BIM code.
# Use models only for labels, legends, issue notes, and visual QA.
# -----------------------------------------------------------------------------
STEP_08_2D_API_KEY_ENV=OPENAI_API_KEY
STEP_08_2D_LABEL_MODEL=gpt-5.4-mini
STEP_08_2D_QA_MODEL=gpt-5.4
STEP_08_2D_FT_METHOD=none_for_geometry__sft_optional_for_labels
STEP_08_2D_LABEL_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_08_2D_LABEL_FT_MODEL=
DRAWING_ENGINE=python_cadquery_ezdxf_svg
DRAWING_OUTPUT_FORMATS=svg,pdf,dxf,png
DRAWING_SCALES=A1:1:200,A1:1:100,A1:1:50
DRAWING_LINEWEIGHT_STYLE=uk_architectural_portfolio
DRAWING_DIMENSION_STANDARD=metric_mm

# -----------------------------------------------------------------------------
# Step 09 — 3D/BIM/geometric model generation from same ProjectGraph
# Do not fine-tune geometry. Generate via Blender/FreeCAD/CadQuery/IFC.
# -----------------------------------------------------------------------------
STEP_09_3D_API_KEY_ENV=OPENAI_API_KEY
STEP_09_3D_QA_MODEL=gpt-5.4
STEP_09_3D_FT_METHOD=none_for_geometry__vision_ft_optional_for_visual_qa
STEP_09_3D_VISION_FT_BASE_MODEL=gpt-4o-2024-08-06
STEP_09_3D_VISION_FT_MODEL=
GEOMETRY_ENGINE=blender_python_freecad_cadquery
BLENDER_EXECUTABLE=blender
FREECAD_EXECUTABLE=freecadcmd
IFC_EXPORT_ENABLED=true
GLB_EXPORT_ENABLED=true
OBJ_EXPORT_ENABLED=true
USDZ_EXPORT_ENABLED=false
RENDER_ENGINE=cycles
RENDER_RESOLUTION_PREVIEW=1600x1000
RENDER_RESOLUTION_A1=4961x3508

# -----------------------------------------------------------------------------
# Step 10 — renders, concept imagery, material mood, local-style image support
# Use image generation as presentation support, not as source of truth for plans/sections.
# -----------------------------------------------------------------------------
STEP_10_IMAGE_API_KEY_ENV=OPENAI_IMAGES_API_KEY
STEP_10_IMAGE_MODEL=gpt-image-2
STEP_10_IMAGE_FT_METHOD=not_currently_for_openai_image_generation
STEP_10_STYLE_CLASSIFIER_MODEL=gpt-5.4-mini
STEP_10_STYLE_CLASSIFIER_FT_METHOD=vision_sft
STEP_10_STYLE_CLASSIFIER_FT_BASE_MODEL=gpt-4o-2024-08-06
STEP_10_STYLE_CLASSIFIER_FT_MODEL=
IMAGE_REFERENCE_PACK_PATH=data/style_reference/riba_uk_local_portfolio
IMAGE_OUTPUT_FORMAT=png
IMAGE_STRICT_NO_FAKE_TECHNICAL_DRAWINGS=true

# Optional external image/model training providers for LoRA/controlnet workflows.
# Only use if you have rights to the training images and model license allows commercial use.
REPLICATE_API_TOKEN=
RUNPOD_API_KEY=
STABILITY_API_KEY=
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# Step 11 — materials, products, construction logic, carbon/EPD
# -----------------------------------------------------------------------------
STEP_11_MATERIALS_API_KEY_ENV=OPENAI_API_KEY
STEP_11_MATERIALS_MODEL=gpt-5.4
STEP_11_MATERIALS_FT_METHOD=sft
STEP_11_MATERIALS_FT_BASE_MODEL=gpt-4.1-mini-2025-04-14
STEP_11_MATERIALS_FT_MODEL=
MATERIAL_LIBRARY_PATH=data/materials/uk_materials
EPD_API_KEY=
EC3_API_KEY=
ICE_DATABASE_PATH=data/carbon/ice_database
MATERIAL_DEFAULT_REGION=UK
MATERIAL_REQUIRE_LOCAL_AVAILABILITY_CHECK=true

# -----------------------------------------------------------------------------
# Step 12 — A1 RIBA-style sheet layout and portfolio narrative
# -----------------------------------------------------------------------------
STEP_12_A1_SHEET_API_KEY_ENV=OPENAI_API_KEY
STEP_12_A1_SHEET_MODEL=gpt-5.4
STEP_12_A1_SHEET_TEMPERATURE=0.35
STEP_12_A1_SHEET_FT_METHOD=sft_then_dpo
STEP_12_A1_SHEET_FT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_12_A1_SHEET_DPO_BASE_MODEL=gpt-4.1-2025-04-14
STEP_12_A1_SHEET_FT_MODEL=
STEP_12_A1_SHEET_DPO_MODEL=
A1_SHEET_WIDTH_MM=841
A1_SHEET_HEIGHT_MM=594
A1_SHEET_DPI=300
A1_EXPORT_FORMATS=pdf,png,svg
A1_LAYOUT_ENGINE=deterministic_grid_layout
A1_TEMPLATE_LIBRARY_PATH=templates/a1_riba_style
A1_BRAND_MODE=user_desire_plus_local_context
A1_INCLUDE_REQUIRED_VIEWS=site_plan,ground_plan,typical_plan,sections,elevations,axonometric,render,programme,concept,materials,environment,regulation_summary

# -----------------------------------------------------------------------------
# Step 13 — cross-consistency QA, buildability, regulation warnings, evals
# -----------------------------------------------------------------------------
STEP_13_QA_API_KEY_ENV=OPENAI_API_KEY
STEP_13_QA_MODEL=gpt-5.4
STEP_13_QA_TEMPERATURE=0.0
STEP_13_QA_FT_METHOD=rft_for_reasoning__sft_for_checklist_format
STEP_13_QA_SFT_BASE_MODEL=gpt-4.1-2025-04-14
STEP_13_QA_RFT_BASE_MODEL=o4-mini-2025-04-16
STEP_13_QA_SFT_MODEL=
STEP_13_QA_RFT_MODEL=
QA_FAIL_ON_2D_3D_MISMATCH=true
QA_FAIL_ON_PROGRAMME_AREA_MISMATCH=true
QA_FAIL_ON_SCHEMA_INVALID=true
QA_WARN_ON_UNVERIFIED_REGULATION=true
QA_MINIMUM_SCORE_TO_EXPORT=0.86
EVALS_ENABLED=true
EVALS_DATASET_PATH=evals/architecture_platform
EVALS_GRADERS_PATH=evals/graders

# -----------------------------------------------------------------------------
# Data, RAG, storage, queues
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/architecture_ai
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=architecture-ai-artifacts
S3_REGION=eu-west-2
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_URL=postgresql://postgres:postgres@localhost:5432/architecture_ai
VECTOR_DB_COLLECTION_REGULATIONS=uk_regulations
VECTOR_DB_COLLECTION_PRECEDENTS=architecture_precedents
VECTOR_DB_COLLECTION_MATERIALS=uk_materials

# -----------------------------------------------------------------------------
# Security, licensing, governance
# -----------------------------------------------------------------------------
ALLOW_USER_UPLOADED_PRECEDENTS=true
REQUIRE_SOURCE_RIGHTS_CONFIRMATION=true
REDACT_PERSONAL_DATA_IN_TRAINING=true
TRAINING_DATA_BUCKET=architecture-ai-training-data
TRAINING_DATA_PATH=data/fine_tuning
DO_NOT_TRAIN_ON_USER_PROJECTS_WITHOUT_CONSENT=true
LICENSE_AUDIT_ENABLED=true

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
PROMPT_VERSION=architecture-platform-v1


