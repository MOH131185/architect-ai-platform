# Current React/Vercel compatibility aliases
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=REPLACE_ME_OPENWEATHER_API_KEY
REACT_APP_OPENWEATHER_API_KEY=REPLACE_ME_OPENWEATHER_API_KEY
REACT_APP_GOOGLE_MAPS_API_KEY=REPLACE_ME_GOOGLE_MAPS_API_KEY
OPENAI_REASONING_API_KEY=REPLACE_ME_OPENAI_API_KEY
OPENAI_IMAGES_API_KEY=REPLACE_ME_OPENAI_API_KEY
REACT_APP_OPENAI_API_KEY=
REACT_APP_USE_TOGETHER=false
TOGETHER_API_KEY=
REACT_APP_API_PROXY_URL=
REACT_APP_BASE_URL=http://localhost:3000
REACT_APP_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
